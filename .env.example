# ---- Telegram ----
# Токен бота (BotFather -> /newbot)
TELEGRAM_BOT_TOKEN=

# Chat ID владельца (узнать проще всего через @userinfobot или /start в самом боте —
# он пришлёт ID в ответе первому пользователю, если TELEGRAM_OWNER_CHAT_ID пуст).
# Только этот chat_id будет получать уведомления и принимать команды.
TELEGRAM_OWNER_CHAT_ID=

# ---- DeepSeek (FreeDeepSeekAPI) ----
# OpenAI-совместимый endpoint прокси. Запущен из соседнего проекта FreeDeepSeekAPI.
DEEPSEEK_API_BASE=http://127.0.0.1:8080/v1

# Токен DeepSeek (см. ../FreeDeepSeekAPI/README.md -> "Get auth token").
# Если пусто — будет использован DEEPSEEK_AUTH_TOKEN со стороны FreeDeepSeekAPI.
DEEPSEEK_API_KEY=

# Модель: deepseek-chat (V3) быстрее, deepseek-reasoner (R1) умнее.
DEEPSEEK_MODEL=deepseek-chat

# ---- Kwork ----
# Как часто опрашивать биржу (секунды). Новые проекты появляются раз в ~10–30 сек.
KWORK_POLL_INTERVAL=45

# Максимум проектов, которые отправим в AI за один цикл (защита от флуда при первом запуске).
KWORK_MAX_AI_PER_CYCLE=8

# Сколько самых старых проектов считать "уже виденными" при первом запуске,
# чтобы бот не завалил чат сотнями старых задач. 0 = отправлять всё с первого цикла.
KWORK_SEED_SEEN=12

# ---- Storage ----
SQLITE_PATH=./data/kwork_bot.sqlite3

# ---- Logging ----
LOG_LEVEL=INFO

# ---- Cookie refresh ----
# Для Docker/серверного деплоя: URL админ-endpoint'а прокси, который
# обновит cookies внутри своего контейнера. Секрет по умолчанию совпадает
# с DEEPSEEK_API_KEY.
# COOKIE_REFRESH_URL=http://deepseek:8080/admin/refresh-cookies
# COOKIE_REFRESH_SECRET=
# Для локального запуска (бот и прокси на одной машине с X-сессией):
# указать путь к shell-скрипту. По умолчанию бот сам находит его в
# ../FreeDeepSeekAPI/refresh_cookies.sh.
# COOKIE_REFRESH_SCRIPT=
